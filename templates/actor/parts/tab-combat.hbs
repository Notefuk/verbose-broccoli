        {{#if legendaryTraitsCombat.hasBonuses}}
        <div class="lt-combat-panel">
          <div class="section-header">
            <i class="fas fa-crown"></i> Legendary Traits (Permanent)
          </div>
          <div class="lt-combat-grid">
            {{#each legendaryTraitsCombat.entries}}
            <div class="lt-combat-entry">
              <div class="lt-combat-name">{{name}} <small>({{sourceName}})</small></div>
              {{#if bonuses.length}}
              <div class="lt-combat-bonuses">
                {{#each bonuses}}<span class="lt-combat-bonus">{{this}}</span>{{/each}}
              </div>
              {{/if}}
              {{#if conditionals.length}}
              <div class="lt-combat-conditionals">
                {{#each conditionals}}<span class="lt-combat-conditional">{{this}}</span>{{/each}}
              </div>
              {{/if}}
            </div>
            {{/each}}
          </div>
          {{!-- Legendary Trait triggered effects now in Available Resources --}}
        </div>
        {{/if}}
    </div>
    {{!-- Tab: Resources --}}
    <div class="tb-tab-content {{#if (eq combatTabsState.traitsBonusesTab 'resources')}}active{{/if}}" data-tab-content="resources">
        <div class="combat-resources-body">
          {{#if combatResourceGroups.length}}
          <div class="resource-filter-controls">
            <label class="filter-toggle"><input type="checkbox" class="combat-filter" data-filter="passive" checked /> Passive</label>
            <label class="filter-toggle"><input type="checkbox" class="combat-filter" data-filter="limited" checked /> Limited</label>
            <label class="filter-toggle"><input type="checkbox" class="combat-filter" data-filter="triggered" checked /> Triggered</label>
          </div>
            {{#each combatResourceGroups}}
            <div class="combat-resource-group">
              <div class="combat-resource-group-header">{{label}}</div>
              {{#each resources}}
              <div class="combat-resource-item type-{{activationType}}" data-effect-id="{{id}}" data-limit="{{usageLimit}}" data-max="{{maxUses}}">
                <div class="resource-info">
                  <span class="resource-name">{{sourceName}}</span>
                  {{#if sourceLabel}}<span class="resource-source-label">({{sourceLabel}})</span>{{/if}}
                  {{#if level}}<span class="resource-level">Lv{{level}}</span>{{/if}}
                  <span class="resource-keyword">[{{keyword}}]</span>
                  <div class="resource-text">{{{text}}}</div>
                </div>
                {{#if hasAction}}
                <div class="resource-controls">
                  {{#if hasCap}}
                  <div class="usage-tracker">
                    {{#each pips}}
                    <span class="usage-pip {{#if available}}available{{/if}}"></span>
                    {{/each}}
                  </div>
                  {{else}}
                    {{#if (gt usedCount 0)}}
                    <span class="resource-use-count">{{usedCount}}x</span>
                    {{/if}}
                  {{/if}}
                  <button type="button" class="use-btn" data-action="unified-action"
                    data-effect-id="{{id}}"
                    data-action-type="{{actionType}}"
                    data-trigger-id="{{triggerId}}"
                    data-stance="{{stanceId}}"
                    data-limit="{{usageLimit}}"
                    data-max-uses="{{maxUses}}"
                    {{#if isMaxed}}disabled{{/if}}>{{buttonLabel}}</button>
                </div>
                {{/if}}
              </div>
              {{/each}}
            </div>
            {{/each}}
          {{else}}
          <div class="empty-message">No combat resources available.</div>
          {{/if}}
        </div>
    </div>
  </div>

  {{!-- Combat Grid --}}
  <div class="combat-grid">

    {{!-- GOD MANEUVERS (only if God Ki is active) --}}
    {{#if system.godKi.active}}
    <div class="combat-panel combat-panel-god-ki">
      <div class="section-header god-ki-header">
        <i class="fas fa-sun"></i> God Maneuvers
        <span class="dkp-inline">
          DKP: <strong>{{system.divineKiPoints.value}}</strong> / {{system.divineKiPoints.max}}
          <button type="button" data-action="dkp-sub" class="dkp-counter-btn" title="-1 DKP"><i class="fas fa-minus"></i></button>
          <button type="button" data-action="dkp-add" class="dkp-counter-btn" title="+1 DKP"><i class="fas fa-plus"></i></button>
          <button type="button" data-action="dkp-refill" class="dkp-counter-btn" title="Refill to max"><i class="fas fa-sync-alt"></i></button>
        </span>
      </div>
      <div class="god-ki-state-effects">
        <div class="god-ki-effect"><span class="god-ki-badge passive">Passive</span> Access to Divine Ki Points</div>
        <div class="god-ki-effect"><span class="god-ki-badge passive">Passive</span> Auto-succeed Concealment vs non-God Ki sensors</div>
        <div class="god-ki-effect"><span class="god-ki-badge passive">Passive</span> +{{system.godKi.woundBonus}} Wound Rolls &amp; Soak Value</div>
      </div>
      <div class="god-maneuvers-list">
        {{#each godManeuverEntries}}
        <div class="god-maneuver-card" data-maneuver-id="{{id}}">
          <div class="god-maneuver-header">
            <span class="god-maneuver-name">{{name}}</span>
            <span class="god-maneuver-freq">{{frequency}}</span>
            <span class="god-maneuver-type">{{maneuverType}}</span>
          </div>
          <div class="god-maneuver-meta">
            <span><strong>Actions:</strong> {{actionCost}}</span>
            <span><strong>DKP:</strong> {{dkpCost}}</span>
          </div>
          <div class="god-maneuver-effect">{{effect}}</div>
          {{#if (eq id "god_strike")}}
          <div class="god-maneuver-config">
            <label>Profile: </label>
            <select class="god-strike-profile" data-maneuver="god_strike">
              {{selectOptions ../profileOptions selected=../godStrikeProfile}}
            </select>
          </div>
          {{/if}}
          <div class="god-maneuver-actions">
            <button type="button" class="god-maneuver-use-btn" data-action="god-maneuver-use"
                    data-maneuver-id="{{id}}" data-dkp-cost="{{dkpCost}}">
              <i class="fas fa-bolt"></i> Use
            </button>
          </div>
        </div>
        {{else}}
        <div class="empty-message">No God Maneuvers selected. Add them from your transformation traits.</div>
        {{/each}}
      </div>
      <div class="god-maneuver-controls">
        <button type="button" data-action="add-god-maneuver" class="action-btn"><i class="fas fa-plus"></i> Add God Maneuver</button>
        <button type="button" data-action="remove-god-maneuver" class="action-btn danger"><i class="fas fa-minus"></i> Remove</button>
      </div>

      {{!-- Divine Aura Builder --}}
      {{#if godHasDivineAura}}
      <div class="god-builder-section">
        <div class="god-builder-header"><i class="fas fa-shield-alt"></i> Divine Aura <span class="god-builder-tag">50 TP Free + Required State (God Ki)</span></div>
        <div class="god-builder-fields">
          <div class="god-builder-row">
            <label>Name</label>
            <input type="text" name="system.divineAura.name" value="{{system.divineAura.name}}" placeholder="Divine Aura name..." />
          </div>
          <div class="god-builder-row">
            <label>KP Cost</label>
            <input type="number" name="system.divineAura.kpCost" value="{{system.divineAura.kpCost}}" min="0" />
          </div>
          <div class="god-builder-row">
            <label>Advantages</label>
            <textarea name="system.divineAura.advantages" rows="2" placeholder="List advantages and ranks...">{{system.divineAura.advantages}}</textarea>
          </div>
          <div class="god-builder-row">
            <label>Effect</label>
            <textarea name="system.divineAura.effect" rows="3" placeholder="Describe the aura effect...">{{system.divineAura.effect}}</textarea>
          </div>
        </div>
      </div>
      {{/if}}

      {{!-- God Finisher Builder --}}
      {{#if godHasFinisher}}
      <div class="god-builder-section">
        <div class="god-builder-header"><i class="fas fa-meteor"></i> God Finisher <span class="god-builder-tag">50 TP Free + Required State (God Ki)</span></div>
        <div class="god-builder-fields">
          <div class="god-builder-row">
            <label>Name</label>
            <input type="text" name="system.godFinisherTechnique.name" value="{{system.godFinisherTechnique.name}}" placeholder="God Finisher name..." />
          </div>
          <div class="god-builder-row">
            <label>KP Cost</label>
            <input type="number" name="system.godFinisherTechnique.kpCost" value="{{system.godFinisherTechnique.kpCost}}" min="0" />
          </div>
          <div class="god-builder-row">
            <label>Profile</label>
            <select name="system.godFinisherTechnique.profile">
              {{selectOptions profileOptions selected=system.godFinisherTechnique.profile}}
            </select>
          </div>
          <div class="god-builder-row">
            <label>Advantages</label>
            <textarea name="system.godFinisherTechnique.advantages" rows="2" placeholder="List advantages and ranks...">{{system.godFinisherTechnique.advantages}}</textarea>
          </div>
          <div class="god-builder-row">
            <label>Effect</label>
            <textarea name="system.godFinisherTechnique.effect" rows="3" placeholder="Describe the technique effect...">{{system.godFinisherTechnique.effect}}</textarea>
          </div>
        </div>
      </div>
      {{/if}}

    </div>
    {{/if}}

    {{!-- CENTER: Resources Used --}}
    <div class="combat-panel combat-panel-used">
      <div class="section-header">
        Turn Resources Used
        <span class="round-indicator">Round {{combatRound}}</span>
      </div>
      <div class="combat-used-summary">
        <span>Round: {{combatRoundUses}} uses</span>
        <span>Encounter: {{combatEncounterUses}} uses</span>
      </div>
      <div class="combat-panel-body combat-used-body">
        {{#each combatUsedResources}}
        <div class="combat-used-item" data-effect-id="{{id}}">
          <span class="used-name">{{sourceName}} <small>Lv{{level}}</small></span>
          {{#if hasCap}}
          <div class="used-pips">
            {{#each pips}}
            <span class="usage-pip {{#if available}}available{{/if}}"></span>
            {{/each}}
          </div>
          {{else}}
          <span class="resource-use-count">{{usedCount}}x</span>
          {{/if}}
          <div class="used-controls">
            <button type="button" class="used-control-btn combat-undo-use" data-effect-id="{{id}}" data-limit="{{usageLimit}}" title="Undo"><i class="fas fa-minus"></i></button>
            <button type="button" class="used-control-btn combat-add-use" data-effect-id="{{id}}" data-limit="{{usageLimit}}" title="Add" {{#if isMaxed}}disabled{{/if}}><i class="fas fa-plus"></i></button>
          </div>
        </div>
        {{else}}
        <div class="empty-message">No resources used this turn.</div>
        {{/each}}
      </div>
      <div class="combat-panel-footer">
        <button type="button" data-action="combat-new-round" class="action-btn"><i class="fas fa-sync"></i> New Round</button>
        <button type="button" data-action="combat-new-encounter" class="action-btn danger"><i class="fas fa-redo"></i> New Encounter</button>
      </div>
    </div>

    {{!-- SIZE COMBAT RULES (at end of grid) --}}
    {{#if system.sizeCombatRules.length}}
    <div class="combat-panel combat-panel-size-rules">
      <div class="section-header size-rules-header">
        <i class="fas fa-ruler-combined"></i> Size Combat Rules
        <span class="size-rules-tag">{{system.status.currentSize}}</span>
      </div>
      <div class="combat-panel-body size-rules-body">
        {{#each system.sizeCombatRules}}
        <div class="size-rule-card">
          <span class="size-rule-name">{{name}}</span>
          <span class="size-rule-text">{{text}}</span>
        </div>
        {{/each}}
      </div>
    </div>
    {{/if}}

    {{!-- Damage Tracker Panel (Moved inside grid) --}}
    <div class="combat-panel damage-tracker-panel" style="grid-column: 1 / -1;">
      <div class="section-header damage-tracker-header">
        Damage Tracker
        <span class="damage-tracker-lp">LP: {{system.lifePoints.value}} / {{system.lifePoints.max}}</span>
      </div>
      <div class="damage-tracker-body">
        {{!-- LEFT: Damage Input --}}
        <div class="dmg-input-zone">
          <div class="dmg-input-row">
            <div class="dmg-field">
              <label>Source</label>
              <select class="combat-dmg-input" data-field="source">
                <option value="wound" {{#if (eq system.damageCalc.source "wound")}}selected{{/if}}>Wound Roll</option>
                <option value="dot" {{#if (eq system.damageCalc.source "dot")}}selected{{/if}}>DOT</option>
                <option value="lpReduction" {{#if (eq system.damageCalc.source "lpReduction")}}selected{{/if}}>LP Reduction</option>
              </select>
            </div>
            <div class="dmg-field dmg-wound-only">
              <label>Category</label>
              <select class="combat-dmg-input" data-field="category">
                {{selectOptions dmgCategoryOptions selected=system.damageCalc.category}}
              </select>
            </div>
            <div class="dmg-field dmg-wound-only">
              <label>Defense</label>
              <select class="combat-dmg-input" data-field="defense">
                {{selectOptions defenseOptions selected=system.damageCalc.defense}}
              </select>
            </div>
          </div>
          <div class="dmg-input-row">
            <div class="dmg-field">
              <label>Wound Roll</label>
              <input type="number" class="combat-dmg-input" data-field="woundRoll" value="{{system.damageCalc.woundRoll}}" min="0" />
            </div>
            <div class="dmg-field dmg-wound-only">
              <label>Extra DR</label>
              <input type="number" class="combat-dmg-input" data-field="damageReduction" value="{{system.damageCalc.damageReduction}}" min="0" />
            </div>
            <div class="dmg-field dmg-result">
              <label>Final Damage</label>
              <span class="dmg-result-value">{{system.damageCalc.healthReduction}}</span>
            </div>
          </div>
          <div class="dmg-input-row dmg-actions">
            <button type="button" data-action="apply-damage" class="action-btn dmg-apply-btn">
              <i class="fas fa-heart-broken"></i> Apply Damage
            </button>
            <button type="button" data-action="apply-heal" class="action-btn dmg-heal-btn">
              <i class="fas fa-heart"></i> Heal
            </button>
          </div>
        </div>

        {{!-- CENTER: LP Status --}}
        <div class="dmg-status-zone">
          <div class="dmg-lp-bar-wrapper">
            <div class="dmg-lp-bar-fill" style="width: {{lpPercent}}%"></div>
            <div class="dmg-lp-bar-text">
              <span>{{system.lifePoints.value}}</span> / <span>{{system.lifePoints.max}}</span>
            </div>
          </div>
          <div class="dmg-thresholds">
            <div class="dmg-threshold {{#if system.thresholds.bruised.crossed}}threshold-crossed{{/if}} {{#if system.thresholds.bruised.checked}}threshold-saved{{/if}}" data-threshold="bruised">
              <span class="threshold-label">Bruised</span>
              <span class="threshold-value">{{system.thresholds.bruised.value}}</span>
              <span class="threshold-status">{{#if system.thresholds.bruised.crossed}}{{#if system.thresholds.bruised.checked}}SAVED{{else}}FAILED{{/if}}{{else}}--{{/if}}</span>
              <input type="checkbox" name="system.thresholds.bruised.checked" {{checked system.thresholds.bruised.checked}} class="threshold-check" title="Check = saved (no penalty)" />
            </div>
            <div class="dmg-threshold {{#if system.thresholds.injured.crossed}}threshold-crossed{{/if}} {{#if system.thresholds.injured.checked}}threshold-saved{{/if}}" data-threshold="injured">
              <span class="threshold-label">Injured</span>
              <span class="threshold-value">{{system.thresholds.injured.value}}</span>
              <span class="threshold-status">{{#if system.thresholds.injured.crossed}}{{#if system.thresholds.injured.checked}}SAVED{{else}}FAILED{{/if}}{{else}}--{{/if}}</span>
              <input type="checkbox" name="system.thresholds.injured.checked" {{checked system.thresholds.injured.checked}} class="threshold-check" title="Check = saved (no penalty)" />
            </div>
            <div class="dmg-threshold {{#if system.thresholds.critical.crossed}}threshold-crossed{{/if}} {{#if system.thresholds.critical.checked}}threshold-saved{{/if}}" data-threshold="critical">
              <span class="threshold-label">Critical</span>
              <span class="threshold-value">{{system.thresholds.critical.value}}</span>
              <span class="threshold-status">{{#if system.thresholds.critical.crossed}}{{#if system.thresholds.critical.checked}}SAVED{{else}}FAILED{{/if}}{{else}}--{{/if}}</span>
              <input type="checkbox" name="system.thresholds.critical.checked" {{checked system.thresholds.critical.checked}} class="threshold-check" title="Check = saved (no penalty)" />
            </div>
          </div>
          <div class="dmg-penalties-row">
            <span>Penalties: <strong>-{{system.thresholds.penalties}}</strong></span>
            {{#if hasTopLayer}}
            <span class="bv-status {{#if topLayerBV.broken}}bv-broken{{/if}}" title="{{topLayerBV.name}} Break Value">
              <i class="fas fa-shield-alt"></i> BV: <strong>{{topLayerBV.current}}/{{topLayerBV.max}}</strong>
              {{#if topLayerBV.broken}}<span class="bv-broken-label">BROKEN</span>{{/if}}
            </span>
            {{/if}}
            <span>DOT: <input type="number" class="combat-dot-stacks" name="system.combatTabState.dotStacks" value="{{system.combatTabState.dotStacks}}" min="0" style="width:40px;text-align:center;" /> stacks (<span class="dot-damage-value">{{combatDotDamage}}</span>/turn)</span>
          </div>
        </div>

        {{!-- RIGHT: Damage Log --}}
        <div class="dmg-log-zone">
          <div class="dmg-log-header">
            <span>Damage Log</span>
            <button type="button" class="action-btn" data-action="clear-damage-log" title="Clear log"><i class="fas fa-trash"></i></button>
          </div>
          <div class="dmg-log-body">
            {{#each combatDamageLog}}
              {{#if isLegacy}}
              <div class="dmg-log-event">{{text}}</div>
              {{else}}
              <div class="dmg-log-event {{#if isHeal}}heal{{else}}damage{{/if}}">
                <span class="log-round">R{{round}}</span>
                <span class="log-type type-{{type}}">{{typeLabel}}</span>
                <span class="log-damage">{{#if isHeal}}+{{absDamage}}{{else}}-{{absDamage}}{{/if}}</span>
                <span class="log-lp">{{lpBefore}} &rarr; {{lpAfter}}</span>
                {{#each steadfastBadges}}
                <span class="steadfast-badge {{cls}}" title="{{initial}}: {{rollText}}"><i class="fas fa-{{icon}}"></i>{{initial}}</span>
                {{/each}}
                {{#if hasBreak}}
                <span class="bv-break-tag" title="Break Value reduced by {{breakReduction}}"><i class="fas fa-shield-alt"></i> -{{breakReduction}}</span>
                {{/if}}
              </div>
              {{/if}}
            {{else}}
            <div class="empty-message">No damage recorded.</div>
            {{/each}}
          </div>
        </div>
      </div>
    </div>

    {{!-- Combat Conditions Panel (Moved inside grid) --}}
    <div class="combat-panel combat-conditions-panel" style="grid-column: 1 / -1;">
      <div class="section-header">
        Combat Conditions
        <span class="conditions-round-badge">Round {{combatRound}}</span>
      </div>
      <div class="combat-conditions-grid">
        {{#each combatConditions}}
        <div class="combat-condition-card {{#if active}}active{{/if}}">
          <div class="condition-card-header">
            <input type="checkbox" class="condition-toggle" data-condition-id="{{id}}" {{#if active}}checked{{/if}} />
            <span class="condition-name">{{name}}</span>
            {{#if (gt maxStacks 1)}}
            <div class="condition-stacks">
              <label>S:</label>
              <input type="number" class="condition-stack-input" data-condition-id="{{id}}" value="{{stacks}}" min="0" max="{{maxStacks}}" />
              <span>/ {{maxStacks}}</span>
            </div>
            {{/if}}
          </div>
          <div class="condition-card-effect">{{effect}}</div>
        </div>
        {{/each}}
      </div>
    </div>

    {{#if hasQuickCombatResources}}
    <div class="combat-panel combat-conditions-panel" style="grid-column: 1 / -1;">
      <div class="section-header">
        <i class="fas fa-gauge-high"></i> Quick Resources
      </div>
      <div class="combat-resource-list">
        {{#each quickCombatResources}}
        <div class="combat-resource-item">
          <div class="resource-main">
            <span class="resource-name">{{label}}</span>
            <span class="resource-uses">{{value}}{{#if max}} / {{max}}{{/if}}</span>
          </div>
        </div>
        {{/each}}
      </div>
    </div>
    {{/if}}

    {{!-- COMBAT COUNTERS (Energy Charges, Power Stacks, Diminishing D/O, God Ki toggle) --}}
    <div class="combat-panel combat-counters-panel" style="grid-column: 1 / -1;">
      <div class="section-header">
        <i class="fas fa-sliders"></i> Combat Counters
      </div>
      <div class="combat-counters-grid">
        <div class="counter-item">
          <label>Energy Charges</label>
          <div class="counter">
            <button type="button" class="counter-btn minus" data-field="system.tracking.energyCharges" data-action="decrease">-</button>
            <input type="number" name="system.tracking.energyCharges" value="{{system.tracking.energyCharges}}" min="0" />
            <button type="button" class="counter-btn plus" data-field="system.tracking.energyCharges" data-action="increase">+</button>
          </div>
        </div>
        <div class="counter-item">
          <label>Power Stacks</label>
          <div class="counter">
            <button type="button" class="counter-btn minus" data-field="system.tracking.powerStacks" data-action="decrease">-</button>
            <input type="number" name="system.tracking.powerStacks" value="{{system.tracking.powerStacks}}" min="0" />
            <button type="button" class="counter-btn plus" data-field="system.tracking.powerStacks" data-action="increase">+</button>
          </div>
        </div>
        <div class="counter-item">
          <label>Diminishing Defense</label>
          <div class="counter">
            <button type="button" class="counter-btn minus" data-field="system.tracking.diminishingDefense" data-action="decrease">-</button>
            <input type="number" name="system.tracking.diminishingDefense" value="{{system.tracking.diminishingDefense}}" min="0" />
            <button type="button" class="counter-btn plus" data-field="system.tracking.diminishingDefense" data-action="increase">+</button>
          </div>
        </div>
        <div class="counter-item">
          <label>Diminishing Offense</label>
          <div class="counter">
            <button type="button" class="counter-btn minus" data-field="system.tracking.diminishingOffense" data-action="decrease">-</button>
            <input type="number" name="system.tracking.diminishingOffense" value="{{system.tracking.diminishingOffense}}" min="0" />
            <button type="button" class="counter-btn plus" data-field="system.tracking.diminishingOffense" data-action="increase">+</button>
          </div>
        </div>
      </div>
      <div class="god-ki-tracking">
        <label class="god-ki-toggle">
          <input type="checkbox" name="system.godKi.permanent" {{#if system.godKi.permanent}}checked{{/if}} />
          <span class="god-ki-label">Permanent God Ki</span>
        </label>
        {{#if system.godKi.active}}
        <span class="god-ki-active-badge"><i class="fas fa-sun"></i> God Ki Active</span>
        {{/if}}
      </div>
    </div>

    {{#if tfRules.hasTransformations}}
    <div class="combat-panel combat-conditions-panel" style="grid-column: 1 / -1;">
      <div class="tf-combat-panel">
        <div class="section-header">
          <i class="fas fa-bolt"></i> Transformation Rules
        </div>
        <div class="tf-combat-grid">
          <div class="tf-combat-item">
            <div class="tf-combat-label"><i class="fas fa-dice"></i> Stress Test</div>
            <div class="tf-combat-info">
              <span class="tf-combat-stat">Bonus: <b>+{{stressBonus}}</b></span>
              {{#if tfRules.combinedStressTest}}
              <span class="tf-combat-stat tf-stat-warn">ST: {{tfRules.combinedStressTest}}</span>
              {{/if}}
              {{#if tfRules.stepByStepReduction}}
              <span class="tf-combat-stat tf-stat-good">Step: -{{tfRules.stepByStepReduction}}</span>
              {{/if}}
            </div>
            <button type="button" class="tf-combat-btn" data-action="tf-stress-test" title="Roll 1d10+1 + Stress Bonus vs Combined ST">
              <i class="fas fa-dice-d20"></i> Roll
            </button>
          </div>
          {{#if tfRules.turbulentPowerActive}}
          <div class="tf-combat-item tf-item-warn">
            <div class="tf-combat-label"><i class="fas fa-exclamation-triangle"></i> Turbulent Power</div>
            <div class="tf-combat-info">
              <span class="tf-combat-stat">Start-of-turn ST</span>
            </div>
            <button type="button" class="tf-combat-btn tf-btn-warn" data-action="tf-turbulent-roll" title="Roll Stress Test at start of turn">
              <i class="fas fa-dice-d20"></i> Roll
            </button>
          </div>
          {{/if}}
          <div class="tf-combat-item">
            <div class="tf-combat-label"><i class="fas fa-forward"></i> Surging Strength</div>
            <div class="tf-combat-info">
              <span class="tf-combat-stat">Rnd: {{tfRules.surgingStrengthRound}}/{{tfRules.surgingRoundLimit}}</span>
              {{#if tfRules.heartbeatActive}}
              <span class="tf-combat-stat tf-stat-heartbeat">Enc: {{tfRules.surgingStrengthEncounter}} (âˆž)</span>
              {{else}}
              <span class="tf-combat-stat">Enc: {{tfRules.surgingStrengthEncounter}}/3</span>
              {{/if}}
            </div>
            <button type="button" class="tf-combat-btn" data-action="tf-surging-strength" {{#if tfRules.surgingDisabled}}disabled{{/if}} title="Use Surging Strength ({{tfRules.surgingRoundLimit}}/Rnd, {{tfRules.surgingEncounterLimit}}/Enc)">
              <i class="fas fa-bolt"></i> Use
            </button>
          </div>
          {{#each tfRules.gradedTransformations}}
          <div class="tf-combat-item tf-combat-kaioken">
            <div class="tf-combat-label"><i class="fas fa-heart-broken" style="color:#e91e63"></i> {{name}} G{{grade}}</div>
            <div class="tf-combat-info">
              <span class="tf-combat-stat">LP Cost: {{lpCostNum}}</span>
              <span class="tf-combat-stat">({{lpCostFormula}})</span>
            </div>
            <button type="button" class="tf-combat-btn tf-btn-danger" data-action="pay-kaioken-lp" data-catalog-key="{{catalogKey}}" title="Pay {{lpCostNum}} LP for {{name}} Grade {{grade}}">
              <i class="fas fa-minus-circle"></i> Pay LP
            </button>
          </div>
          {{/each}}
          {{#if tfRules.noLpRegen}}
          <div class="tf-combat-item tf-combat-warning">
            <div class="tf-combat-label"><i class="fas fa-heart-broken" style="color:#ff1744"></i> No LP Regen</div>
            <div class="tf-combat-info"><span class="tf-combat-stat tf-stat-danger">Cannot regain Life Points</span></div>
          </div>
          {{/if}}
          {{#if tfRules.crimsonAcclimationActive}}
          <div class="tf-combat-item tf-combat-warning">
            <div class="tf-combat-label"><i class="fas fa-exclamation-triangle" style="color:#ff9800"></i> Crimson Acclimation</div>
            <div class="tf-combat-info"><span class="tf-combat-stat tf-stat-warn">+2 Combined ST, +2(bT) LP Cost</span></div>
          </div>
          {{/if}}
          <div class="tf-combat-item">
            <div class="tf-combat-label"><i class="fas fa-fire"></i> Burst Limit</div>
            <div class="tf-combat-info">
              {{#if tfRules.burstThroughAvailable}}
              <span class="tf-combat-stat tf-stat-warn">Burst Through!</span>
              {{else if tfRules.burstLimitUsed}}
              <span class="tf-combat-stat tf-stat-used">Used: {{tfRules.burstLimitSource}}</span>
              {{else}}
              <span class="tf-combat-stat tf-stat-good">Available</span>
              {{/if}}
            </div>
            <button type="button" class="tf-combat-btn" data-action="tf-burst-limit" {{#if tfRules.burstLimitUsed}}{{#unless tfRules.burstThroughAvailable}}disabled{{/unless}}{{/if}} title="{{#if tfRules.burstThroughAvailable}}Burst Through Your Limit (NLoP + first EP entry){{else}}Trigger Burst Limit (1/Encounter, any EP){{/if}}">
              <i class="fas fa-fire-alt"></i> {{#if tfRules.burstThroughAvailable}}Burst Through{{else}}Trigger{{/if}}
            </button>
          </div>
          {{#if tfRules.hasActiveAFLF}}
          <div class="tf-combat-item">
            <div class="tf-combat-label"><i class="fas fa-star"></i> Legend Realized</div>
            <div class="tf-combat-info">
              <span class="tf-combat-stat">{{tfRules.legendRealizedCount}}/{{tfRules.legendRealizedMax}} used</span>
            </div>
            <button type="button" class="tf-combat-btn tf-btn-legend" data-action="tf-legend-realized" {{#if tfRules.legendRealizedAllUsed}}disabled{{/if}} title="Roll 2d10(T) + PL, restore LP+KP (1/Transformation/Enc)">
              <i class="fas fa-dice-d20"></i> Roll
            </button>
          </div>
          {{/if}}
          <div class="tf-combat-item">
            <div class="tf-combat-label"><i class="fas fa-level-up-alt"></i> New Level of Power</div>
            <div class="tf-combat-info">
              <span class="tf-combat-stat">Marked: {{tfRules.nlopCount}}</span>
              {{#if tfRules.nlopTierBoost}}
              <span class="tf-combat-stat tf-stat-good">+{{tfRules.nlopTierBoost}} Tier Active</span>
              {{/if}}
            </div>
            <button type="button" class="tf-combat-btn" data-action="tf-new-level-of-power" {{#unless tfRules.nlopHasEligible}}disabled{{/unless}} title="Mark first-time entry (+1 ToP, +1(bT) Stress, no ST required)">
              <i class="fas fa-plus"></i> Mark
            </button>
          </div>
          {{#if tfRules.kiMultiplierActive}}
          <div class="tf-combat-item tf-item-info">
            <div class="tf-combat-label"><i class="fas fa-bolt"></i> Ki Multiplier</div>
            <div class="tf-combat-info">
              <span class="tf-combat-stat tf-stat-good">KP x2, Cap x1.5</span>
            </div>
            <span class="tf-combat-badge">Active</span>
          </div>
          {{/if}}
        </div>
        {{#if tfRules.nlopActiveEncounter.length}}
        <div class="tf-nlop-active">
          <small><i class="fas fa-level-up-alt"></i> NLoP active:</small>
          {{#each tfRules.nlopActiveEncounter}}
          <span class="tf-nlop-tag">{{this}}</span>
          {{/each}}
        </div>
        {{/if}}
      </div>
    </div>
    {{/if}}

  </div>
</div>
