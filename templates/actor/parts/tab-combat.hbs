<div class="combat-container">

  {{!-- ==================== INITIATIVE ADVANTAGE ==================== --}}
  {{#if inCombat}}
  <div class="initiative-advantage-section">
    <div class="ia-header">
      <i class="fas fa-bolt-lightning"></i> Initiative
      <span class="ia-value">Value: {{currentInitiative}}</span>
      {{#if doubleInitiativeAdvantage}}
        <span class="ia-badge ia-badge-double"><i class="fas fa-bolt-lightning"></i><i class="fas fa-bolt-lightning"></i> Double Initiative Advantage</span>
      {{else if initiativeAdvantage}}
        <span class="ia-badge ia-badge-single"><i class="fas fa-bolt-lightning"></i> Initiative Advantage</span>
      {{/if}}
      {{#if lowestInitiative}}
        <span class="ia-badge ia-badge-lowest"><i class="fas fa-hourglass-end"></i> Lowest Initiative</span>
      {{/if}}
    </div>
    <div class="ia-details">
      <span class="ia-detail">Base (AG/2): {{system.aptitudes.initiative}}</span>
      {{#if (gt system.aptitudes.initiativeRollBonus 0)}}
        <span class="ia-detail">Roll Bonus: +{{system.aptitudes.initiativeRollBonus}}</span>
      {{/if}}
      {{#if (gt system.aptitudes.initiativeValue 0)}}
        <span class="ia-detail ia-init-value"><i class="fas fa-arrow-up"></i> Value: +{{system.aptitudes.initiativeValue}}</span>
      {{/if}}
      {{#if system.aptitudes.alertReroll}}
        <span class="ia-detail ia-alert"><i class="fas fa-eye"></i> Alert: 2d10kh</span>
      {{/if}}
    </div>
  </div>
  {{/if}}

  {{!-- Round Tracker (full-width, outside grid) --}}
  <div class="combat-panel combat-panel-tracker">
    <div class="section-header">Round Tracker
      <span class="round-indicator">Round {{combatRound}}</span>
    </div>

    {{!-- KI Summary Bar --}}
    <div class="tracker-ki-bar">
      <div class="ki-stat">
        <label>KI</label>
        <span class="ki-display">{{system.kiPool.value}} / {{system.kiPool.max}}</span>
      </div>
      <div class="ki-stat">
        <label>Power-Ups</label>
        <span class="ki-display">{{combatPowerUpCount}}</span>
      </div>
      <div class="ki-stat">
        <label>Capacity</label>
        <span class="ki-display">{{system.status.capacityLeft}} / {{system.status.maxCapacity}}</span>
      </div>
      <div class="ki-stat ki-control">
        <label>
          <input type="checkbox" class="perfect-ki-control" data-action="toggle-perfect-ki" {{#if system.combatTabState.perfectKiControl}}checked{{/if}} />
          Perfect KI Control
        </label>
      </div>
    </div>

    {{!-- Ki Wager Limits Reference --}}
    <div class="ki-wager-ref collapsed">
      <div class="ki-wager-ref-header" data-action="toggle-ki-wager-ref">
        <i class="fas fa-bolt"></i> Ki Wager Limits
        <i class="fas fa-chevron-down ki-wager-chevron"></i>
      </div>
      <div class="ki-wager-ref-body">
        <div class="ki-wager-row default">
          <span class="ki-wager-label">Default (Attacks/Techs)</span>
          <span class="ki-wager-value">{{kiWagerLimits.default}}</span>
        </div>
        <div class="ki-wager-row">
          <span class="ki-wager-label">Duel (per clash)</span>
          <span class="ki-wager-value">{{kiWagerLimits.duel}}</span>
        </div>
        <div class="ki-wager-row">
          <span class="ki-wager-label">Throw</span>
          <span class="ki-wager-value">{{kiWagerLimits.throw}}</span>
        </div>
        <div class="ki-wager-row">
          <span class="ki-wager-label">Elemental Earth</span>
          <span class="ki-wager-value">{{kiWagerLimits.elementalEarth}}</span>
        </div>
        <div class="ki-wager-row">
          <span class="ki-wager-label">Deflect (Power Struggle)</span>
          <span class="ki-wager-value">{{kiWagerLimits.deflectPS}}</span>
        </div>
        <div class="ki-wager-row">
          <span class="ki-wager-label">United Duel</span>
          <span class="ki-wager-value">{{kiWagerLimits.unitedDuel}}</span>
        </div>
        <div class="ki-wager-row zero">
          <span class="ki-wager-label">Absorb / Feint</span>
          <span class="ki-wager-value">0</span>
        </div>
      </div>
    </div>

    {{!-- Split layout: Activables sidebar + Rounds --}}
    <div class="rt-split">
      {{!-- LEFT: Activables sidebar --}}
      <div class="rt-activables">
        <div class="rt-activables-header">
          <i class="fas fa-bolt"></i> Activables
        </div>
        <div class="rt-activables-list">
          {{#if combatResourceGroups.length}}
          <div class="resource-filter-controls">
            <label class="filter-toggle"><input type="checkbox" class="combat-filter" data-filter="passive" checked /> Passive</label>
            <label class="filter-toggle"><input type="checkbox" class="combat-filter" data-filter="limited" checked /> Limited</label>
            <label class="filter-toggle"><input type="checkbox" class="combat-filter" data-filter="triggered" checked /> Triggered</label>
          </div>
          {{#each combatResourceGroups}}
            {{#each resources}}
            {{#if hasAction}}
            <div class="rt-activable type-{{activationType}}" data-effect-id="{{id}}">
              <button type="button" class="rt-activable-btn {{#if isMaxed}}maxed{{/if}}" data-action="rt-activable-use"
                data-effect-id="{{id}}" data-action-type="{{actionType}}" data-trigger-id="{{triggerId}}"
                data-stance="{{stanceId}}" data-limit="{{usageLimit}}" data-max-uses="{{maxUses}}"
                data-source-name="{{sourceName}}" title="{{sourceLabel}} — {{sourceName}}{{#if text}}&#10;{{text}}{{/if}}" {{#if isMaxed}}disabled{{/if}}>
                <span class="rt-activable-status"></span>
                <span class="rt-activable-name">{{sourceName}}</span>
                {{#if usageLabel}}<span class="rt-activable-limit">{{usageLabel}}</span>{{/if}}
                {{#if hasCap}}
                <span class="rt-activable-pips">
                  {{#each pips}}<span class="usage-pip {{#if available}}available{{/if}}"></span>{{/each}}
                </span>
                {{else}}
                <span class="rt-activable-count">{{#if (gt usedCount 0)}}{{usedCount}}x{{else}}&#x221E;{{/if}}</span>
                {{/if}}
              </button>
            </div>
            {{/if}}
            {{/each}}
          {{/each}}
          {{else}}
          <div class="empty-message">No activables available. Equip techniques or transformations to see quick-use buttons here.</div>
          {{/if}}
        </div>
      </div>

      {{!-- RIGHT: Rounds --}}
      <div class="rt-rounds">
        {{!-- Rounds Container --}}
        <div class="combat-panel-body tracker-rounds-container">
          {{#each combatRounds}}
          <div class="tracker-round {{#if isActive}}active{{else}}locked{{/if}}" data-round="{{roundNumber}}">
            <div class="tracker-round-header">
              <span>Round {{roundNumber}}</span>
              <span class="round-ki-total">KI: {{kiTotal}}{{#if @root.system.godKi.active}} | DKP: {{dkpTotal}}{{/if}}</span>
            </div>
            <div class="tracker-round-content">
              {{#each actions}}
              {{#if ../isActive}}
              <div class="tracker-action" data-action-index="{{@index}}">
                <select class="action-type" data-round="{{../roundNumber}}" data-action-index="{{@index}}">
                  <option value="instant" {{#if (eq type "instant")}}selected{{/if}}>Instant</option>
                  <option value="standard" {{#if (eq type "standard")}}selected{{/if}}>Standard</option>
                  <option value="out-of-sequence" {{#if (eq type "out-of-sequence")}}selected{{/if}}>Out-of-Seq</option>
                  <option value="power-up" {{#if (eq type "power-up")}}selected{{/if}}>Power-Up</option>
                  <option value="ki" {{#if (eq type "ki")}}selected{{/if}}>Ki</option>
                  <option value="attack" {{#if (eq type "attack")}}selected{{/if}}>Attack</option>
                </select>
                {{#if (eq type "attack")}}
                <select class="action-source" data-round="{{../roundNumber}}" data-action-index="{{@index}}" data-current-source="{{source}}">
                  <option value="">-- Select --</option>
                </select>
                {{/if}}
                <input type="number" class="action-ki" data-round="{{../roundNumber}}" data-action-index="{{@index}}" value="{{kiCost}}" placeholder="KI" min="0" />
                {{#if @root.system.godKi.active}}
                <input type="number" class="action-dkp" data-round="{{../roundNumber}}" data-action-index="{{@index}}" value="{{dkpCost}}" placeholder="DKP" min="0" title="Divine Ki Points spent (1/2 capacity rate)" />
                {{/if}}
                <input type="text" class="action-desc" data-round="{{../roundNumber}}" data-action-index="{{@index}}" value="{{description}}" placeholder="Description..." />
                <button type="button" class="action-delete-btn" data-action="delete-tracker-action" data-round="{{../roundNumber}}" data-action-index="{{@index}}"><i class="fas fa-times"></i></button>
              </div>
              {{else}}
              <div class="tracker-action past-action">
                <span class="action-type-label">{{type}}</span>
                <span class="action-ki-label">{{#if kiCost}}KI: {{kiCost}}{{/if}}{{#if dkpCost}} DKP: {{dkpCost}}{{/if}}</span>
                <span class="action-desc-label">{{description}}{{#if source}} [{{source}}]{{/if}}</span>
              </div>
              {{/if}}
              {{/each}}
            </div>
          </div>
          {{else}}
          <div class="empty-message">No rounds recorded. Click <strong>+ Action</strong> to start tracking your turn.</div>
          {{/each}}
        </div>

        {{!-- Tracker Controls --}}
        <div class="tracker-controls">
          <button type="button" data-action="tracker-add-action" class="action-btn primary"><i class="fas fa-plus"></i> Action</button>
          <button type="button" data-action="tracker-next-round" class="action-btn"><i class="fas fa-forward"></i> Next Round</button>
          <button type="button" data-action="tracker-reset" class="action-btn danger"><i class="fas fa-trash"></i> Reset</button>
        </div>
      </div>
    </div>
  </div>

  {{!-- ==================== EXTRA DICE POOLS ==================== --}}
  <div class="dice-pools-section">
    <div class="dp-header" data-action="toggle-dice-pools">
      <i class="fas fa-dice-d20"></i> Extra Dice Pools
      <i class="fas fa-chevron-down dp-toggle-icon"></i>
    </div>
    <div class="dp-body">
      <table class="dp-table">
        <thead>
          <tr>
            <th></th>
            <th>ToP Extra Dice</th>
            <th>Greater Dice</th>
            <th>ToP Cat. Bonus</th>
            <th>Greater Cat. Bonus</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="dp-roll-type">Strike</td>
            <td class="dp-dice-val">{{dicePoolsSummary.strike.top}}</td>
            <td class="dp-dice-val">{{dicePoolsSummary.strike.greater}}</td>
            <td><input type="number" class="dp-input" name="system.dicePools.topCatBonus.strike" value="{{dicePools.topCatBonus.strike}}" /></td>
            <td><input type="number" class="dp-input" name="system.dicePools.greaterCatBonus.strike" value="{{dicePools.greaterCatBonus.strike}}" /></td>
          </tr>
          <tr>
            <td class="dp-roll-type">Wound</td>
            <td class="dp-dice-val">{{dicePoolsSummary.wound.top}}</td>
            <td class="dp-dice-val">{{dicePoolsSummary.wound.greater}}</td>
            <td><input type="number" class="dp-input" name="system.dicePools.topCatBonus.wound" value="{{dicePools.topCatBonus.wound}}" /></td>
            <td><input type="number" class="dp-input" name="system.dicePools.greaterCatBonus.wound" value="{{dicePools.greaterCatBonus.wound}}" /></td>
          </tr>
          <tr>
            <td class="dp-roll-type">Dodge</td>
            <td class="dp-dice-val">{{dicePoolsSummary.dodge.top}}</td>
            <td class="dp-dice-val">{{dicePoolsSummary.dodge.greater}}</td>
            <td><input type="number" class="dp-input" name="system.dicePools.topCatBonus.dodge" value="{{dicePools.topCatBonus.dodge}}" /></td>
            <td><input type="number" class="dp-input" name="system.dicePools.greaterCatBonus.dodge" value="{{dicePools.greaterCatBonus.dodge}}" /></td>
          </tr>
        </tbody>
        <tfoot>
          <tr>
            <td class="dp-roll-type">Global</td>
            <td colspan="2" class="dp-note">Applies to all roll types</td>
            <td><input type="number" class="dp-input" name="system.dicePools.topCatBonus.global" value="{{dicePools.topCatBonus.global}}" /></td>
            <td><input type="number" class="dp-input" name="system.dicePools.greaterCatBonus.global" value="{{dicePools.greaterCatBonus.global}}" /></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  {{#if hasSpecialTransformationResources}}
  <div class="combat-card">
    <div class="combat-card-header">
      <i class="fas fa-vial"></i> Transformation Resources
    </div>
    <div class="combat-resource-list">
      {{#each specialTransformationResources}}
      <div class="combat-resource-item">
        <div class="resource-main">
          <span class="resource-name">{{label}}</span>
          <span class="resource-uses">{{value}}{{#if max}} / {{max}}{{/if}}</span>
        </div>
        {{#if sourceName}}
        <div class="resource-meta">{{sourceName}}</div>
        {{/if}}
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{#if hasUniverseSeed}}
  <div class="combat-card">
    <div class="combat-card-header">
      <i class="fas fa-seedling"></i> Universe Seed
    </div>
    <div class="combat-resource-list">
      <div class="combat-resource-item">
        <div class="resource-main">
          <span class="resource-name">Universal Power</span>
          <input type="number" name="system.universeSeed.universalPower" value="{{universeSeed.universalPower}}" min="0" step="1" style="width:90px" />
        </div>
        <div class="resource-meta">Integrated: {{#if universeSeed.integrated}}Yes{{else}}No{{/if}}</div>
      </div>
    </div>
  </div>
  {{/if}}


  {{!-- ==================== TRAITS & BONUSES UNIFIED PANEL ==================== --}}
  <div class="tb-panel">
    <div class="tb-tabs-nav">
      <button type="button" class="tb-tab-btn {{#if (eq combatTabsState.traitsBonusesTab 'racial')}}active{{/if}}" data-action="tb-tab-switch" data-tab="racial">
        <i class="fas fa-dna"></i> Racial
        {{#if tbTabBadges.racial}}<span class="tb-tab-badge">{{tbTabBadges.racial}}</span>{{/if}}
      </button>
      <button type="button" class="tb-tab-btn {{#if (eq combatTabsState.traitsBonusesTab 'talents')}}active{{/if}}" data-action="tb-tab-switch" data-tab="talents">
        <i class="fas fa-gem"></i> Talents
        {{#if tbTabBadges.talents}}<span class="tb-tab-badge">{{tbTabBadges.talents}}</span>{{/if}}
      </button>
      <button type="button" class="tb-tab-btn {{#if (eq combatTabsState.traitsBonusesTab 'mp')}}active{{/if}}" data-action="tb-tab-switch" data-tab="mp">
        <i class="fas fa-star-of-life"></i> MP
        {{#if tbTabBadges.mp}}<span class="tb-tab-badge">{{tbTabBadges.mp}}</span>{{/if}}
      </button>
      <button type="button" class="tb-tab-btn {{#if (eq combatTabsState.traitsBonusesTab 'ep')}}active{{/if}}" data-action="tb-tab-switch" data-tab="ep">
        <i class="fas fa-bolt"></i> EP
        {{#if tbTabBadges.ep}}<span class="tb-tab-badge">{{tbTabBadges.ep}}</span>{{/if}}
      </button>
      <button type="button" class="tb-tab-btn {{#if (eq combatTabsState.traitsBonusesTab 'af')}}active{{/if}}" data-action="tb-tab-switch" data-tab="af">
        <i class="fas fa-exchange-alt"></i> AF
        {{#if tbTabBadges.af}}<span class="tb-tab-badge">{{tbTabBadges.af}}</span>{{/if}}
      </button>
      <button type="button" class="tb-tab-btn {{#if (eq combatTabsState.traitsBonusesTab 'lf')}}active{{/if}}" data-action="tb-tab-switch" data-tab="lf">
        <i class="fas fa-crown"></i> LF
        {{#if tbTabBadges.lf}}<span class="tb-tab-badge">{{tbTabBadges.lf}}</span>{{/if}}
      </button>
      <button type="button" class="tb-tab-btn {{#if (eq combatTabsState.traitsBonusesTab 'resources')}}active{{/if}}" data-action="tb-tab-switch" data-tab="resources">
        <i class="fas fa-scroll"></i> Resources
        {{#if tbTabBadges.resources}}<span class="tb-tab-badge">{{tbTabBadges.resources}}</span>{{/if}}
      </button>
    </div>

    {{!-- Tab: Racial --}}
    <div class="tb-tab-content {{#if (eq combatTabsState.traitsBonusesTab 'racial')}}active{{/if}}" data-tab-content="racial">

      {{!-- ==================== BATTLE BORN TRACKER (Saiyan only) ==================== --}}
      {{#if isSaiyan}}
      <div class="battle-born-tracker">
        <div class="bb-header">
          <i class="fas fa-fist-raised"></i> Battle Born Tracker
          <span class="bb-total">Total: {{system.battleBorn.total}}/{{system.battleBorn.maxTotal}}</span>
          <label class="bb-undying-toggle">
            <input type="checkbox" name="system.battleBorn.undying" {{#if system.battleBorn.undying}}checked{{/if}} />
            Undying L3 (max 3)
          </label>
        </div>
        <div class="bb-allocations">
          <div class="bb-row" data-bb-type="strike">
            <span class="bb-label">Strike</span>
            <button type="button" class="bb-decrement" data-bb-type="strike" {{#if (eq system.battleBorn.strike 0)}}disabled{{/if}}><i class="fas fa-minus"></i></button>
            <div class="bb-pips">
              {{#each bbStrikePips}}<span class="bb-pip {{#if filled}}filled{{/if}}"></span>{{/each}}
            </div>
            <button type="button" class="bb-increment" data-bb-type="strike" {{#if (gte system.battleBorn.strike system.battleBorn.cap)}}disabled{{/if}}><i class="fas fa-plus"></i></button>
            <span class="bb-bonus">+{{system.battleBorn.strikeBonus}}</span>
          </div>
          <div class="bb-row" data-bb-type="dodge">
            <span class="bb-label">Dodge</span>
            <button type="button" class="bb-decrement" data-bb-type="dodge" {{#if (eq system.battleBorn.dodge 0)}}disabled{{/if}}><i class="fas fa-minus"></i></button>
            <div class="bb-pips">
              {{#each bbDodgePips}}<span class="bb-pip {{#if filled}}filled{{/if}}"></span>{{/each}}
            </div>
            <button type="button" class="bb-increment" data-bb-type="dodge" {{#if (gte system.battleBorn.dodge system.battleBorn.cap)}}disabled{{/if}}><i class="fas fa-plus"></i></button>
            <span class="bb-bonus">+{{system.battleBorn.dodgeBonus}}</span>
          </div>
          <div class="bb-row" data-bb-type="wound">
            <span class="bb-label">Wound</span>
            <button type="button" class="bb-decrement" data-bb-type="wound" {{#if (eq system.battleBorn.wound 0)}}disabled{{/if}}><i class="fas fa-minus"></i></button>
            <div class="bb-pips">
              {{#each bbWoundPips}}<span class="bb-pip {{#if filled}}filled{{/if}}"></span>{{/each}}
            </div>
            <button type="button" class="bb-increment" data-bb-type="wound" {{#if (gte system.battleBorn.wound system.battleBorn.cap)}}disabled{{/if}}><i class="fas fa-plus"></i></button>
            <span class="bb-bonus">+{{system.battleBorn.woundBonus}}</span>
          </div>
        </div>

        {{!-- Derived Bonuses --}}
        {{#if hasRacialBonuses}}
        <div class="bb-derived">
          <div class="bonus-cards-grid">
            {{#if racialBonuses.has.primitiveDurability}}
            <div class="bonus-card cat-armor" title="Primitive Durability (Battle Born)">
              <div class="bonus-card-header"><i class="fas fa-shield-alt"></i> Primitive Dur.</div>
              <div class="bonus-card-value">+{{racialBonuses.primitiveDurabilitySoak}}</div>
              <div class="bonus-card-stat">Soak</div>
            </div>
            {{/if}}
            {{#if racialBonuses.has.greaterPotential}}
            <div class="bonus-card cat-offense" title="Greater Potential (Battle Born)">
              <div class="bonus-card-header"><i class="fas fa-fire"></i> Greater Pot.</div>
              <div class="bonus-card-value">+{{racialBonuses.greaterPotentialWound}}</div>
              <div class="bonus-card-stat">Wound</div>
              {{#if (eq racialBonuses.greaterPotentialWound 0)}}<div class="bonus-card-note">need 4+ stacks</div>{{/if}}
            </div>
            {{/if}}
            {{#if racialBonuses.has.powerfulPhysique}}
            <div class="bonus-card cat-armor" title="Powerful Physique (Battle Born)">
              <div class="bonus-card-header"><i class="fas fa-dumbbell"></i> Powerful Phys.</div>
              <div class="bonus-card-value">+{{racialBonuses.powerfulPhysiqueSoak}}</div>
              <div class="bonus-card-stat">Soak</div>
            </div>
            {{/if}}
            {{#if racialBonuses.has.warriorsPride}}
            <div class="bonus-card cat-saves" title="Warrior's Pride (Battle Born)">
              <div class="bonus-card-header"><i class="fas fa-crown"></i> Warrior's Pride</div>
              <div class="bonus-card-value">+{{racialBonuses.warriorsPrideBonus}}</div>
              <div class="bonus-card-stat">Cognitive Save</div>
            </div>
            {{/if}}
          </div>
        </div>
        {{/if}}
      </div>
      {{/if}}

      {{!-- ==================== EARTHLING TRACKER (Earthling only) ==================== --}}
      {{#if isEarthling}}
      <div class="earthling-tracker">
        <div class="earthling-header">
          <i class="fas fa-user-shield"></i> Earthling Traits
        </div>

        {{!-- Experienced Fighter Mode Selector --}}
        {{#if earthlingBonuses.has.experiencedFighter}}
        <div class="ef-section">
          <div class="ef-label">
            Experienced Fighter
            <span class="ef-cost">Cost: {{earthlingBonuses.efKiCost}} Ki</span>
            {{#if efUsedThisRound}}<span class="ef-lock"><i class="fas fa-lock"></i> Used</span>{{/if}}
          </div>
          <div class="ef-modes">
            <button type="button" class="ef-mode-btn {{#if (eq efMode 'strike')}}active{{/if}}"
              data-action="ef-activate" data-ef-mode="strike"
              {{#unless efCanActivate}}{{#unless (eq efMode 'strike')}}disabled{{/unless}}{{/unless}}>
              <i class="fas fa-crosshairs"></i> Strike +{{earthlingBonuses.efStrikeBonus}}
            </button>
            <button type="button" class="ef-mode-btn {{#if (eq efMode 'dodge')}}active{{/if}}"
              data-action="ef-activate" data-ef-mode="dodge"
              {{#unless efCanActivate}}{{#unless (eq efMode 'dodge')}}disabled{{/unless}}{{/unless}}>
              <i class="fas fa-running"></i> Dodge +{{earthlingBonuses.efDodgeBonus}}
            </button>
            <button type="button" class="ef-mode-btn {{#if (eq efMode 'wound')}}active{{/if}}"
              data-action="ef-activate" data-ef-mode="wound"
              {{#unless efCanActivate}}{{#unless (eq efMode 'wound')}}disabled{{/unless}}{{/unless}}>
              <i class="fas fa-skull-crossbones"></i> Wound +{{earthlingBonuses.efWoundBonus}} / DC+{{earthlingBonuses.efDamageCategoryBonus}}
            </button>
            {{#unless (eq efMode 'none')}}
            <button type="button" class="ef-mode-btn ef-deactivate" data-action="ef-deactivate">
              <i class="fas fa-times"></i> Off
            </button>
            {{/unless}}
          </div>
        </div>
        {{/if}}

        {{!-- Derived Bonuses Display --}}
        {{#if hasEarthlingBonuses}}
        <div class="earthling-derived">
          <span class="earthling-derived-label">Active Bonuses ({{earthlingBonuses.thresholdsBelow}} threshold{{#if (gt earthlingBonuses.thresholdsBelow 1)}}s{{/if}} below):</span>
